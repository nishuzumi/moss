{
  "name": "@themoss/example-simple-nft-mint",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "compile": "hardhat compile",
    "deploy:testnet": "hardhat run scripts/deploy.ts --network monadTestnet",
    "mint:testnet": "tsx src/simple-mint.mts",
    "price:testnet": "hardhat run scripts/read-price.ts --network monadTestnet",
    "verify:testnet": "hardhat verify --network monadTestnet",
    "typecheck": "tsc --noEmit",
    "test": "hardhat test && vitest run",
    "build": "hardhat compile"
  },
  "dependencies": {
    "@themoss/core": "workspace:*",
    "@themoss/protocol-nft-mint": "workspace:*",
    "@themoss/simulator": "workspace:*",
    "@themoss/system": "workspace:*",
    "viem": "^2.54.3"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^3.1.0",
    "@nomicfoundation/hardhat-verify": "^2.1.0",
    "@openzeppelin/contracts": "^5.4.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.20.0",
    "dotenv": "^17.2.3",
    "ethers": "^6.16.0",
    "hardhat": "^2.28.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.0",
    "typescript": "~5.9.0",
    "vitest": "^3.2.6"
  }
}
