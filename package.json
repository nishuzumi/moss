{
  "name": "moss-monorepo",
  "private": true,
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:offline": "MOSS_SKIP_E2E=1 pnpm test",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "changeset": "changeset",
    "fetch-abi": "pnpm --filter @themoss/abi-tools fetch-abi"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^22.20.0",
    "typescript": "~5.9.0"
  }
}
