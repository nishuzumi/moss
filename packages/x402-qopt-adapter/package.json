{
  "name": "@themoss/x402-qopt-adapter",
  "version": "0.0.0",
  "private": true,
  "description": "x402 service adapter for pay-per-solve QUBO optimization APIs",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
